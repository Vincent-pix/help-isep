# Copier ce fichier vers backend/.env et renseigner les valeurs

NODE_ENV=production
PORT=3001

# Base MySQL — variables séparées (local / VPS)
DB_HOST=localhost
DB_PORT=3306
DB_USER=help_isep_user
DB_PASSWORD=change_me
DB_NAME=help_isep

# Railway : lier le service MySQL (référence automatique, une seule suffit)
# DATABASE_URL=mysql://user:pass@host:port/help_isep
# MYSQL_URL=mysql://user:pass@host:port/help_isep

# Secret JWT (générer une longue chaîne aléatoire, ex. openssl rand -base64 48)
JWT_SECRET=change_me_long_secret

# Origines autorisées pour CORS (séparées par des virgules)
# Exemple déploiement séparé : https://www.votre-domaine.fr
# Exemple même domaine (API + front sur le même serveur) : https://votre-domaine.fr
CORS_ORIGINS=https://votre-domaine.fr,https://www.votre-domaine.fr

# true = le backend sert aussi le build React (frontend/dist)
# false sur Railway (front sur Vercel)
SERVE_FRONTEND=false
